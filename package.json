{
  "name": "@studio-corsair/mcp-uptime-kuma",
  "version": "1.0.0",
  "mcpName": "io.github.studio-corsair/mcp-uptime-kuma",
  "description": "A Model Context Protocol (MCP) server for Uptime Kuma version 2, supporting both stdio and streamable HTTP transports. Fork of @davidfuchs/mcp-uptime-kuma with additional write operations.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-uptime-kuma": "dist/index.js",
    "mcp-uptime-kuma-get-jwt": "dist/get-jwt.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js -t stdio",
    "start:http": "node dist/index.js -t streamable-http",
    "dev": "tsx src/index.ts",
    "dev:stdio": "tsx src/index.ts -t stdio",
    "dev:http": "tsx src/index.ts -t streamable-http",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "test:integration": "cd test/integration && ./run-tests.sh",
    "test:integration:direct": "tsx test/integration/integration.test.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "server",
    "stdio",
    "http",
    "uptime",
    "kuma",
    "uptime kuma"
  ],
  "author": "Studio Corsair",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/studio-corsair/mcp-uptime-kuma.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "@types/cors": "^2.8.19",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "fuzzysort": "^3.1.0",
    "node-cache": "^5.1.2",
    "socket.io-client": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/node-cache": "^4.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
