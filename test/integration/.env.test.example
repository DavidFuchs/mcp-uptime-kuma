# Uptime Kuma test instance configuration
# Copy this file to .env.test and fill in your values

UPTIME_KUMA_URL=http://localhost:3001
UPTIME_KUMA_USERNAME=admin
UPTIME_KUMA_PASSWORD=your_password_here

# Alternative: Use JWT token instead of username/password - probably not ideal for integration testing
# due to the hassle of getting the JWT token. Might as well use a simple username/password.
# UPTIME_KUMA_JWT_TOKEN=your_jwt_token_here
